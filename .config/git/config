[init]
	defaultBranch = main

[commit]
	verbose = true

[help]
	autocorrect = 10

[diff]
	algorithm = histogram

[branch]
	sort = -committerdate

[gpg]
        format = ssh

[commit]
        gpgSign = true

[tag]
        gpgSign = true

# Here all the different git users' configuration overrides are listed
[includeIf "gitdir:~/repos/abc-valera/"]
    path = ~/repos/abc-valera/.gitconfig
[includeIf "gitdir:~/repos/hideez/"]
    path = ~/repos/hideez/.gitconfig
[includeIf "gitdir:~/repos/valeriy-o3c/"]
    path = ~/repos/valeriy-o3c/.gitconfig
